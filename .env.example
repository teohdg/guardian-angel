# ===========================================
# Guardian AI - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Twilio (REQUIRED) ---
# Get these from: https://console.twilio.com/ (Account SID)
# Auth Token: https://console.twilio.com/ (Auth Token)
TWILIO_ACCOUNT_SID=PLACEHOLDER
TWILIO_AUTH_TOKEN=PLACEHOLDER
TWILIO_PHONE_NUMBER=+13022795875

# --- OpenAI (REQUIRED for intent classification) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=PLACEHOLDER

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Base URL (REQUIRED for webhooks in production) ---
# Local: ngrok URL (e.g. https://abc123.ngrok.io)
# Production: your deployed domain (e.g. https://guardian-ai.onrender.com)
BASE_URL=https://estrella-huskiest-bewilderingly.ngrok-free.dev
SKIP_TWILIO_VALIDATION=true
